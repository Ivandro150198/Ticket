APP_URL=/Ticket/public
APP_ENV=local

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eventticket_gb
DB_USERNAME=root
DB_PASSWORD=

# SMTP (deixe vazio para gravar em storage/mail.log)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@eventticket-gb.local
MAIL_FROM_NAME=EventTicket-GB

# Stripe (modo test). Sem chaves = pagamento local (simulado / MB ref)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Multibanco / MB Way local (referência gerada; confirmação manual ou auto em demo)
PAYMENT_ENTITY=12345
